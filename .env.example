# OneNote to Notion Sync - Environment Variables

# Microsoft OneNote / Graph API
ONENOTE_CLIENT_ID=your-azure-app-client-id
ONENOTE_TENANT_ID=common

# Notion
NOTION_TOKEN=your-notion-integration-token

# LLM Agent (supports OpenAI, Claude, Gemini, etc.)
AGENT_API_KEY=your-llm-api-key

# Live API Documentation
CONTEXT7_API_KEY=your-context7-api-key
