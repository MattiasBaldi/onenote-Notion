# OneNote to Notion Sync - Environment Variables

# Microsoft OneNote / Graph API
ONENOTE_CLIENT_ID=your-azure-app-client-id
ONENOTE_TENANT_ID=common

# Notion
NOTION_TOKEN=your-notion-integration-token

# LLM Agent Configuration
# Gemini is the cheapest option (default: gemini-2.5-flash-lite)
LLM_PROVIDER=gemini
AGENT_API_KEY=your-gemini-api-key
AGENT_MODEL=gemini-2.5-flash-lite

# Alternative: OpenAI
# LLM_PROVIDER=openai
# AGENT_API_KEY=sk-xxx
# AGENT_MODEL=gpt-4

# Alternative: Local LLM (LM Studio, Ollama)
# LLM_BASE_URL=http://localhost:1234/v1
# AGENT_MODEL=local-model

# Live API Documentation
CONTEXT7_API_KEY=your-context7-api-key
